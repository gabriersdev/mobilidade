    "got": "^11.8.5",
    "tar": "^7.5.7",
    "npm": "latest",
    "ajv": "^6.12.6",
    "minimatch": "^9.0.4",
    "serialize-javascript": "^7.0.5",
    "@tootallnate/once": "^2.0.1",
    "smol-toml": "^1.6.1",
    "srvx": "^0.11.13",
    "glob": "^10.4.1",
    "rimraf": "^5.0.7"
  },
  "sideEffects": [
    "bootstrap/dist/js/bootstrap.bundle.min.js"
  ],
  "allowScripts": {
    "esbuild@0.28.1": true,
    "cypress@15.17.0": true
  }
}
