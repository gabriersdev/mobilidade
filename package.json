{
  "name": "mobilidade",
  "private": true,
  "version": "1.34.0",
  "type": "module",
  "homepage": "https://gabriersdev.github.io/mobilidade",
  "engines": {
    "node": "^22.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-version.js && node scripts/register.build.js && vite build && node scripts/generate-sitemap.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "update": "npm update",
    "upgrade:deps": "npx npm-check-updates -i && npm install",
    "cypress": "npx cypress run",
    "sync:version": "git pull && node scripts/sync-version.js && git add package.json && git commit -m \"build: update version\"",
    "sitemap": "node scripts/generate-sitemap.js"
  },
  "compilerOptions": {
    "jsx": "react-jsx"
  },
  "resolutions": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "dependencies": {
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@rollup/plugin-terser": "^1.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@vercel/speed-insights": "^2.0.0",
    "aos": "^2.3.4",
    "axios": "1.18.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "downshift": "^9.4.0",
    "framer-motion": "^12.42.2",
    "html-react-parser": "^6.1.4",
    "leaflet": "^1.9.4",
    "moment": "^2.30.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-input-mask": "^2.0.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1",
    "rolldown": "1.0.3",
    "semantic-release": "^25.0.8",
    "vercel": "^56.2.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^6.0.3",
    "chalk": "^5.6.2",
    "cypress": "^15.18.1",
    "eslint": "^10.7.0",
    "eslint-plugin-cypress": "6.4.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "globby": "^16.2.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.49.0",
    "vite": "8.0.16"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "qs": "^6.14.1",
    "undici": "^6.23.0",
    "esbuild": "^0.28.1",
    "path-to-regexp": "^6.3.0",
